# Copy this file to .env for local development.
# .env is gitignored and should contain your real local values.

GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=your-bigquery-dataset
BIGQUERY_LOCATION=your-bigquery-location
GOOGLE_APPLICATION_CREDENTIALS=your-google-application-credentials-path
ARCHIVE_IMPORTED_FILES=true
GCS_BUCKET=your-archive-bucket-name
GCS_PREFIX=dev
UPLOAD_LOG_TO_GCS=true
LOG_GCS_PREFIX=log/dev
